<aside class="crm-sidebar @(IsCollapsed ? "collapsed" : string.Empty)">
    <div class="crm-sidebar-header">
        <div>
            <div class="crm-sidebar-title">Comapny Name</div>
            <div class="crm-sidebar-subtitle">CRM</div>
        </div>
        @* <span class="crm-badge crm-badge-accent">MVP</span> *@
    </div>

    <nav class="crm-nav">
        <div class="crm-nav-group">
            <div class="crm-nav-label">Workspace</div>
            <NavLink class="crm-nav-link" href="" Match="NavLinkMatch.All" @onclick="HandleNavigate" title="Dashboard">
                <span class="crm-nav-icon">◌</span>
                <span>Dashboard</span>
            </NavLink>
            <NavLink class="crm-nav-link" href="deals" @onclick="HandleNavigate" title="Deals">
                <span class="crm-nav-icon">◔</span>
                <span>Deals</span>
            </NavLink>
            <NavLink class="crm-nav-link" href="tasks" @onclick="HandleNavigate" title="Tasks">
                <span class="crm-nav-icon">◴</span>
                <span>Tasks</span>
            </NavLink>
            <NavLink class="crm-nav-link" href="contacts" @onclick="HandleNavigate" title="Contacts">
                <span class="crm-nav-icon">◎</span>
                <span>Contacts</span>
            </NavLink>
            <NavLink class="crm-nav-link" href="reports" @onclick="HandleNavigate" title="Reports">
                <span class="crm-nav-icon">◫</span>
                <span>Reports</span>
            </NavLink>
            <NavLink class="crm-nav-link" href="users" @onclick="HandleNavigate" title="Users">
                <span class="crm-nav-icon">◉</span>
                <span>Users</span>
            </NavLink>
        </div>
    </nav>

    <div class="crm-sidebar-footer">
       @*  <div class="crm-sidebar-note">Mobile first, then web.</div>
        <div class="crm-sidebar-meta">Desktop-style shell with in-view scrolling.</div> *@
    </div>
</aside>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback OnNavigate { get; set; }

    private Task HandleNavigate()
    {
        return OnNavigate.InvokeAsync();
    }
}

