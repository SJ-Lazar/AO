@page "/error"

<PageTitle>Error</PageTitle>

<div class="crm-dashboard">
    <section class="crm-card crm-panel crm-panel-wide">
        <div class="crm-panel-header">
            <div>
                <h1>Something went wrong</h1>
                <p>An unexpected application error occurred.</p>
            </div>
        </div>
        <div class="crm-alert crm-alert-danger">Please try again. If the issue continues, check the application log files.</div>
    </section>
</div>
