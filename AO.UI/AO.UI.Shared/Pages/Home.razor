    private async Task SaveDealStageAsync()
    {
        if (selectedDeal is null)
        {
            return;
        }

        isSavingDealStage = true;
        dealDialogErrorMessage = null;

        try
        {
            await CrmApiClient.SetDealStageAsync(selectedDeal.Id, new SetDealStageRequest { Stage = selectedDealStage });
            await LoadDashboardAsync();
            CloseDealDialog();
        }
        catch (Exception exception)
        {
            dealDialogErrorMessage = exception.Message;
        }
        finally
        {
            isSavingDealStage = false;
        }
    }

    private async Task CompleteTaskAsync(Guid taskId)
    {
        if (!completingTaskIds.Add(taskId))
        {
            return;
        }

        errorMessage = null;

        try
        {
            await CrmApiClient.CompleteTaskAsync(taskId);
            await LoadDashboardAsync();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
        finally
        {
            completingTaskIds.Remove(taskId);
        }
    }

    private int GetStageCount(DealStage stage)
    {
        return dashboardSummary.PipelineStages.FirstOrDefault(summary => string.Equals(summary.Stage, stage.ToString(), StringComparison.OrdinalIgnoreCase))?.Count ?? 0;
    }

    private decimal GetStageValue(DealStage stage)
    {
        return dashboardSummary.PipelineStages.FirstOrDefault(summary => string.Equals(summary.Stage, stage.ToString(), StringComparison.OrdinalIgnoreCase))?.Value ?? 0m;
    }

    private static string FormatCurrency(decimal value)
    {
        return value.ToString("C0");
    }

    private static DateTime? NormalizeDateUtc(DateTime? value)
    {
        return value?.Date;
    }

    private static string GetContactSubtitle(ContactDto contact)
    {
        var segments = new[] { contact.AssignedUserName, contact.CompanyName, contact.Email, contact.Phone }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" • ", segments.DefaultIfEmpty("No details yet"));
    }

    private static string GetCompanySubtitle(CompanyDto company)
    {
        var segments = new[]
        {
            company.Industry,
            company.AssignedUserName,
            $"{company.ContactCount} contacts",
            $"{company.OpenDealCount} open deals"
        }.Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" • ", segments);
    }

    private static string GetTaskSubtitle(CrmTaskDto task)
    {
        var segments = new[] { task.AssignedUserName, task.ContactName, task.DealTitle, task.Description }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" • ", segments.DefaultIfEmpty("No details yet"));
    }

    private static string GetDealOwner(DealDto deal)
    {
        if (!string.IsNullOrWhiteSpace(deal.AssignedUserName))
        {
            return deal.AssignedUserName;
        }

        if (!string.IsNullOrWhiteSpace(deal.ContactName))
        {
            return deal.ContactName;
        }

        return "Unassigned";
    }

    private static string GetTaskBadge(CrmTaskDto task)
    {
        if (task.IsCompleted)
        {
            return "Done";
        }

        if (task.DueAtUtc.HasValue)
        {
            return task.DueAtUtc.Value.ToLocalTime().ToString("dd MMM");
        }

        return task.Priority;
    }

    private static string GetDealStageBadgeClass(string stage)
    {
        return stage switch
        {
            nameof(DealStage.Won) => "crm-badge-success",
            nameof(DealStage.Negotiation) => "crm-badge-accent",
            nameof(DealStage.Lost) => "crm-badge-warning",
            _ => string.Empty
        };
    }

    private static string GetDealDateBadge(DealDto deal)
    {
        if (deal.ExpectedCloseDateUtc.HasValue)
        {
            return deal.ExpectedCloseDateUtc.Value.ToLocalTime().ToString("dd MMM");
        }

        return deal.IsClosed ? "Closed" : "Open";
    }

    private string GetRelatedTaskSummary(Guid dealId)
    {
        var relatedTasks = tasks.Where(task => task.DealId == dealId).ToList();
        if (relatedTasks.Count == 0)
        {
            return "None";
        }

        var openTasks = relatedTasks.Count(task => !task.IsCompleted);
        return openTasks == 0 ? "All done" : $"{openTasks} open";
    }

    private static string GetActivitySubtitle(CrmActivityDto activity)
    {
        var segments = new[] { activity.Type, activity.CompanyName, activity.ContactName, activity.DealTitle, activity.TaskTitle, activity.Description }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" • ", segments.DefaultIfEmpty("Recent CRM activity"));
    }

    private static string GetActivityBadge(CrmActivityDto activity)
    {
        return activity.CreatedUtc.ToLocalTime().ToString("dd MMM");
    }

    private static string GetActivityBadgeClass(string activityType)
    {
        return activityType switch
        {
            nameof(CrmActivityType.DealStageChanged) => "crm-badge-accent",
            nameof(CrmActivityType.TaskCompleted) => "crm-badge-success",
            nameof(CrmActivityType.TaskUpdated) => "crm-badge-warning",
            _ => string.Empty
        };
    }

