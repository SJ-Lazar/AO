    private void OpenDealDialog(Guid? dealId = null)
    {
        dealDialogErrorMessage = null;
        selectedDeal = dealId.HasValue
            ? deals.FirstOrDefault(deal => deal.Id == dealId.Value)
            : deals.FirstOrDefault();

        if (selectedDeal is null)
        {
            errorMessage = "No deals are available yet.";
            return;
        }

        if (!Enum.TryParse<DealStage>(selectedDeal.Stage, true, out var parsedStage))
        {
            parsedStage = DealStage.Lead;
        }

        selectedDealStage = parsedStage;

        isDealDialogOpen = true;
    }

