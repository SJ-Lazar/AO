@page "/"
@using AO.Core.Features.Activities
@using AO.Core.Features.Companies
@using AO.Core.Features.Contacts
@using AO.Core.Features.Dashboard
@using AO.Core.Features.Deals
@using AO.Core.Features.Tasks
@using AO.Core.Features.Users
@using AO.UI.Shared.Services
@inject CrmApiClient CrmApiClient
@inject IFormFactor FormFactor

<PageTitle>Home</PageTitle>

<div class="crm-dashboard">
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="crm-alert crm-alert-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div class="crm-alert">Loading CRM workspace...</div>
    }

    <section id="overview" class="crm-hero-card crm-card">
        <div class="crm-hero-copy">
          @*   <span class="crm-eyebrow">Minimal CRM</span> *@
            <h1>Compact customer workspace</h1>
        </div>

        <div class="crm-hero-actions">
            <button type="button" class="crm-button crm-button-primary" @onclick="OpenCreateCompanyModal" disabled="@isLoading">New company</button>
            <button type="button" class="crm-button crm-button-primary" @onclick="OpenCreateContactModal" disabled="@isLoading">New contact</button>
            <button type="button" class="crm-button crm-button-secondary" @onclick="OpenCreateDealModal" disabled="@isLoading">New deal</button>
            <button type="button" class="crm-button crm-button-secondary" @onclick="OpenCreateTaskModal" disabled="@isLoading">New task</button>
        </div>
    </section>

    <section class="crm-stat-grid">
        <article class="crm-card crm-stat-card">
            <span class="crm-stat-label">Pipeline</span>
            <strong>@FormatCurrency(dashboardSummary.OpenPipelineValue)</strong>
            <span class="crm-badge crm-badge-accent">@dashboardSummary.OpenDealCount open</span>
        </article>
        <article class="crm-card crm-stat-card">
            <span class="crm-stat-label">Companies</span>
            <strong>@dashboardSummary.TotalCompanies</strong>
            <span class="crm-badge">@dashboardSummary.TotalContacts contacts</span>
        </article>
        <article class="crm-card crm-stat-card">
            <span class="crm-stat-label">Tasks</span>
            <strong>@dashboardSummary.OpenTaskCount</strong>
            <span class="crm-badge crm-badge-warning">@dashboardSummary.OverdueTaskCount overdue</span>
        </article>
        <article class="crm-card crm-stat-card">
            <span class="crm-stat-label">Users</span>
            <strong>@users.Count</strong>
            <span class="crm-badge crm-badge-success">Assignable team</span>
        </article>
        
    </section>

    <section class="crm-content-grid">
        <article id="pipeline" class="crm-card crm-panel crm-panel-wide">
            <div class="crm-panel-header">
                <div>
                    <h2>Pipeline overview</h2>
                    <p>Compact stage tracking for active revenue.</p>
                </div>
                <div class="crm-inline-actions">
                    <span class="crm-badge">@dashboardSummary.OpenDealCount open</span>
                    <button type="button" class="crm-chip-button" @onclick="OpenCreateDealModal">New deal</button>
                </div>
            </div>

            <div class="crm-stage-grid">
                <div class="crm-stage-card">
                    <span>Lead</span>
                    <strong>@GetStageCount(DealStage.Lead)</strong>
                    <small>@FormatCurrency(GetStageValue(DealStage.Lead))</small>
                </div>
                <div class="crm-stage-card">
                    <span>Qualified</span>
                    <strong>@GetStageCount(DealStage.Qualified)</strong>
                    <small>@FormatCurrency(GetStageValue(DealStage.Qualified))</small>
                </div>
                <div class="crm-stage-card">
                    <span>Proposal</span>
                    <strong>@GetStageCount(DealStage.Proposal)</strong>
                    <small>@FormatCurrency(GetStageValue(DealStage.Proposal))</small>
                </div>
                <div class="crm-stage-card crm-stage-card-accent">
                    <span>Negotiation</span>
                    <strong>@GetStageCount(DealStage.Negotiation)</strong>
                    <small>@FormatCurrency(GetStageValue(DealStage.Negotiation))</small>
                </div>
            </div>

            <div class="crm-list-table">
                <div class="crm-table-row crm-table-head">
                    <span>Deal</span>
                    <span>Owner</span>
                    <span>Value</span>
                    <span>Stage</span>
                </div>
                @if (deals.Count == 0)
                {
                    <div class="crm-table-row">
                        <span class="crm-empty-state">No deals yet.</span>
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                }
                else
                {
                    @foreach (var deal in deals.Take(6))
                    {
                        <button type="button" class="crm-table-row crm-table-button" @onclick="() => OpenDealDialog(deal.Id)">
                            <span>@deal.Title</span>
                            <span>@GetDealOwner(deal)</span>
                            <span>@FormatCurrency(deal.Value)</span>
                            <span><span class="crm-badge @(GetDealStageBadgeClass(deal.Stage))">@deal.Stage</span></span>
                        </button>
                    }
                }
            </div>
        </article>

        <article id="tasks" class="crm-card crm-panel">
            <div class="crm-panel-header">
                <div>
                    <h2>Today</h2>
                    <p>Compact agenda for follow-ups.</p>
                </div>
                <div class="crm-inline-actions">
                    <span class="crm-badge crm-badge-warning">@dashboardSummary.OverdueTaskCount overdue</span>
                    <button type="button" class="crm-chip-button" @onclick="OpenCreateTaskModal">New task</button>
                </div>
            </div>

            <div class="crm-stack-list">
                @if (tasks.Count == 0)
                {
                    <div class="crm-empty-state">No tasks yet.</div>
                }
                else
                {
                    @foreach (var task in tasks.Take(5))
                    {
                        <div class="crm-list-item">
                            <div>
                                <strong>@task.Title</strong>
                                <small>@GetTaskSubtitle(task)</small>
                            </div>
                            <div class="crm-list-item-actions">
                            <span class="crm-badge @(task.IsCompleted ? "crm-badge-success" : task.DueAtUtc.HasValue && task.DueAtUtc.Value.Date < DateTime.UtcNow.Date ? "crm-badge-warning" : string.Empty)">@GetTaskBadge(task)</span>
                                @if (!task.IsCompleted)
                                {
                                    <button type="button" class="crm-chip-button" @onclick="() => CompleteTaskAsync(task.Id)" disabled="@completingTaskIds.Contains(task.Id)">@(completingTaskIds.Contains(task.Id) ? "..." : "Done")</button>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </article>

        <article id="contacts" class="crm-card crm-panel">
            <div class="crm-panel-header">
                <div>
                    <h2>Contacts</h2>
                    <p>Small, dense list with account context.</p>
                </div>
                <button type="button" class="crm-chip-button" @onclick="OpenCreateContactModal">Add</button>
            </div>

            <div class="crm-stack-list">
                @if (contacts.Count == 0)
                {
                    <div class="crm-empty-state">No contacts yet.</div>
                }
                else
                {
                    @foreach (var contact in contacts.Take(5))
                    {
                        <div class="crm-list-item">
                            <div>
                                <strong>@contact.FullName</strong>
                                <small>@GetContactSubtitle(contact)</small>
                            </div>
                            <span class="crm-badge @(contact.IsArchived ? string.Empty : "crm-badge-accent")">@(contact.IsArchived ? "Archived" : "Active")</span>
                        </div>
                    }
                }
            </div>
        </article>

        <article id="reports" class="crm-card crm-panel crm-panel-wide">
            <div class="crm-panel-header">
                <div>
                    <h2>Company snapshot</h2>
                    <p>Live summary from the company and deal slices.</p>
                </div>
                <div class="crm-inline-actions">
                    <span class="crm-badge">@dashboardSummary.ClosedDealCount closed deals</span>
                    <span class="crm-badge crm-badge-accent">@dashboardSummary.RecentActivityCount recent activities</span>
                    <button type="button" class="crm-chip-button" @onclick="OpenCreateCompanyModal">New company</button>
                </div>
            </div>

            <div class="crm-chart-shell">
                <div class="crm-chart-card crm-chart-card-accent">
                    <span>Open pipeline</span>
                    <strong>@FormatCurrency(dashboardSummary.OpenPipelineValue)</strong>
                    <small>@dashboardSummary.TasksDueTodayCount tasks due today</small>
                </div>
                <div class="crm-stack-list">
                    @if (companies.Count == 0)
                    {
                        <div class="crm-empty-state">No companies yet.</div>
                    }
                    else
                    {
                        @foreach (var company in companies.Take(4))
                        {
                            <div class="crm-list-item">
                                <div>
                                    <strong>@company.Name</strong>
                                    <small>@GetCompanySubtitle(company)</small>
                                </div>
                                <span class="crm-badge @(company.IsArchived ? string.Empty : "crm-badge-success")">@(company.IsArchived ? "Archived" : "Active")</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </article>
    </section>

    <section class="crm-surface-grid">
       @*  <article id="modals" class="crm-card crm-panel">
            <div class="crm-panel-header">
                <div>
                    <h2>Modal surface</h2>
                    <p>Compact create and edit flows.</p>
                </div>
                <button type="button" class="crm-button crm-button-secondary" @onclick="OpenCreateCompanyModal">Open modal</button>
            </div>
        </article> *@

       @*  <article id="dialogs" class="crm-card crm-panel">
            <div class="crm-panel-header">
                <div>
                    <h2>Dialog surface</h2>
                    <p>Focused side detail pattern.</p>
                </div>
                <button type="button" class="crm-button crm-button-secondary" @onclick="(() => OpenDealDialog())">Open dialog</button>
            </div>
        </article> *@

        <article id="activity" class="crm-card crm-panel">
            <div class="crm-panel-header">
                <div>
                    <h2>Recent activity</h2>
                    <p>Live CRM history from feature activity logging.</p>
                </div>
                <span class="crm-badge">@recentActivities.Count items</span>
            </div>

            <div class="crm-stack-list">
                @if (recentActivities.Count == 0)
                {
                    <div class="crm-empty-state">No activity yet.</div>
                }
                else
                {
                    @foreach (var activity in recentActivities.Take(6))
                    {
                        <div class="crm-list-item">
                            <div>
                                <strong>@activity.Title</strong>
                                <small>@GetActivitySubtitle(activity)</small>
                            </div>
                            <span class="crm-badge @(GetActivityBadgeClass(activity.Type))">@GetActivityBadge(activity)</span>
                        </div>
                    }
                }
            </div>
        </article>
    </section>
</div>

<CrmModal IsOpen="isCreateCompanyModalOpen" Title="Create company" Subtitle="Compact modal surface" Size="Medium" OnClose="CloseCreateCompanyModal">
    <ChildContent>
        <div class="crm-form-grid">
            <label>
                <span>Name</span>
                <InputText class="crm-input" @bind-Value="companyForm.Name" />
            </label>
            <label>
                <span>Industry</span>
                <InputText class="crm-input" @bind-Value="companyForm.Industry" />
            </label>
            <label>
                <span>Website</span>
                <InputText class="crm-input" @bind-Value="companyForm.Website" />
            </label>
            <label>
                <span>Phone</span>
                <InputText class="crm-input" @bind-Value="companyForm.Phone" />
            </label>
            <label>
                <span>Assigned user</span>
                <InputSelect class="crm-input" @bind-Value="companyForm.AssignedUserId">
                    <option value="">No user</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName</option>
                    }
                </InputSelect>
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(companyModalErrorMessage))
        {
            <div class="crm-alert crm-alert-danger">@companyModalErrorMessage</div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="crm-button crm-button-secondary" @onclick="CloseCreateCompanyModal" disabled="@isSavingCompany">Cancel</button>
        <button type="button" class="crm-button crm-button-primary" @onclick="SaveCompanyAsync" disabled="@isSavingCompany">@(isSavingCompany ? "Saving..." : "Save company")</button>
    </FooterContent>
</CrmModal>

<CrmModal IsOpen="isCreateContactModalOpen" Title="Create contact" Subtitle="Compact modal surface" Size="Medium" OnClose="CloseCreateContactModal">
    <ChildContent>
        <div class="crm-form-grid">
            <label>
                <span>First name</span>
                <InputText class="crm-input" @bind-Value="contactForm.FirstName" />
            </label>
            <label>
                <span>Last name</span>
                <InputText class="crm-input" @bind-Value="contactForm.LastName" />
            </label>
            <label>
                <span>Email</span>
                <InputText class="crm-input" @bind-Value="contactForm.Email" />
            </label>
            <label>
                <span>Phone</span>
                <InputText class="crm-input" @bind-Value="contactForm.Phone" />
            </label>
            <label>
                <span>Job title</span>
                <InputText class="crm-input" @bind-Value="contactForm.JobTitle" />
            </label>
            <label>
                <span>Company</span>
                <InputSelect class="crm-input" @bind-Value="contactForm.CompanyId">
                    <option value="">No company</option>
                    @foreach (var company in companies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Assigned user</span>
                <InputSelect class="crm-input" @bind-Value="contactForm.AssignedUserId">
                    <option value="">No user</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName</option>
                    }
                </InputSelect>
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(modalErrorMessage))
        {
            <div class="crm-alert crm-alert-danger">@modalErrorMessage</div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="crm-button crm-button-secondary" @onclick="CloseCreateContactModal" disabled="@isSavingContact">Cancel</button>
        <button type="button" class="crm-button crm-button-primary" @onclick="SaveContactAsync" disabled="@isSavingContact">@(isSavingContact ? "Saving..." : "Save contact")</button>
    </FooterContent>
</CrmModal>

<CrmModal IsOpen="isCreateDealModalOpen" Title="Create deal" Subtitle="Compact pipeline entry" Size="Medium" OnClose="CloseCreateDealModal">
    <ChildContent>
        <div class="crm-form-grid">
            <label>
                <span>Title</span>
                <InputText class="crm-input" @bind-Value="dealForm.Title" />
            </label>
            <label>
                <span>Value</span>
                <InputNumber class="crm-input" @bind-Value="dealForm.Value" />
            </label>
            <label>
                <span>Stage</span>
                <InputSelect class="crm-input" @bind-Value="dealForm.Stage">
                    @foreach (var stage in Enum.GetValues<DealStage>())
                    {
                        <option value="@stage">@stage</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Close date</span>
                <InputDate class="crm-input" @bind-Value="dealForm.ExpectedCloseDateUtc" />
            </label>
            <label>
                <span>Company</span>
                <InputSelect class="crm-input" @bind-Value="dealForm.CompanyId">
                    <option value="">No company</option>
                    @foreach (var company in companies)
                    {
                        <option value="@company.Id">@company.Name</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Contact</span>
                <InputSelect class="crm-input" @bind-Value="dealForm.ContactId">
                    <option value="">No contact</option>
                    @foreach (var contact in contacts)
                    {
                        <option value="@contact.Id">@contact.FullName</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Assigned user</span>
                <InputSelect class="crm-input" @bind-Value="dealForm.AssignedUserId">
                    <option value="">No user</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName</option>
                    }
                </InputSelect>
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(dealModalErrorMessage))
        {
            <div class="crm-alert crm-alert-danger">@dealModalErrorMessage</div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="crm-button crm-button-secondary" @onclick="CloseCreateDealModal" disabled="@isSavingDeal">Cancel</button>
        <button type="button" class="crm-button crm-button-primary" @onclick="SaveDealAsync" disabled="@isSavingDeal">@(isSavingDeal ? "Saving..." : "Save deal")</button>
    </FooterContent>
</CrmModal>

<CrmModal IsOpen="isCreateTaskModalOpen" Title="Create task" Subtitle="Compact follow-up action" Size="Medium" OnClose="CloseCreateTaskModal">
    <ChildContent>
        <div class="crm-form-grid">
            <label>
                <span>Title</span>
                <InputText class="crm-input" @bind-Value="taskForm.Title" />
            </label>
            <label>
                <span>Priority</span>
                <InputSelect class="crm-input" @bind-Value="taskForm.Priority">
                    @foreach (var priority in Enum.GetValues<CrmTaskPriority>())
                    {
                        <option value="@priority">@priority</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Description</span>
                <InputText class="crm-input" @bind-Value="taskForm.Description" />
            </label>
            <label>
                <span>Due date</span>
                <InputDate class="crm-input" @bind-Value="taskForm.DueAtUtc" />
            </label>
            <label>
                <span>Contact</span>
                <InputSelect class="crm-input" @bind-Value="taskForm.ContactId">
                    <option value="">No contact</option>
                    @foreach (var contact in contacts)
                    {
                        <option value="@contact.Id">@contact.FullName</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Deal</span>
                <InputSelect class="crm-input" @bind-Value="taskForm.DealId">
                    <option value="">No deal</option>
                    @foreach (var deal in deals)
                    {
                        <option value="@deal.Id">@deal.Title</option>
                    }
                </InputSelect>
            </label>
            <label>
                <span>Assigned user</span>
                <InputSelect class="crm-input" @bind-Value="taskForm.AssignedUserId">
                    <option value="">No user</option>
                    @foreach (var user in users)
                    {
                        <option value="@user.Id">@user.FullName</option>
                    }
                </InputSelect>
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(taskModalErrorMessage))
        {
            <div class="crm-alert crm-alert-danger">@taskModalErrorMessage</div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="crm-button crm-button-secondary" @onclick="CloseCreateTaskModal" disabled="@isSavingTask">Cancel</button>
        <button type="button" class="crm-button crm-button-primary" @onclick="SaveTaskAsync" disabled="@isSavingTask">@(isSavingTask ? "Saving..." : "Save task")</button>
    </FooterContent>
</CrmModal>

<CrmDialog IsOpen="isDealDialogOpen" Title="Deal details" Subtitle="Negotiation summary" OnClose="CloseDealDialog">
    <ChildContent>
        @if (selectedDeal is null)
        {
            <div class="crm-empty-state">No deal selected.</div>
        }
        else
        {
            <div class="crm-stack-list">
                <div class="crm-list-item">
                    <div>
                        <strong>Account</strong>
                        <small>@(selectedDeal.CompanyName ?? "No company linked")</small>
                    </div>
                    <span class="crm-badge @(selectedDeal.IsClosed ? string.Empty : "crm-badge-accent")">@(selectedDeal.IsClosed ? "Closed" : "Open")</span>
                </div>
                <div class="crm-list-item">
                    <div>
                        <strong>Value</strong>
                        <small>@FormatCurrency(selectedDeal.Value)</small>
                    </div>
                    <span class="crm-badge">@selectedDeal.Stage</span>
                </div>
                <div class="crm-list-item">
                    <div>
                        <strong>Primary contact</strong>
                        <small>@(selectedDeal.ContactName ?? "Unassigned")</small>
                    </div>
                    <span class="crm-badge crm-badge-warning">@GetDealDateBadge(selectedDeal)</span>
                </div>
                <div class="crm-list-item">
                    <div>
                        <strong>Related tasks</strong>
                        <small>@tasks.Count(task => task.DealId == selectedDeal.Id) linked tasks</small>
                    </div>
                    <span class="crm-badge">@GetRelatedTaskSummary(selectedDeal.Id)</span>
                </div>
                <label class="crm-field">
                    <span>Stage</span>
                    <InputSelect class="crm-input" @bind-Value="selectedDealStage">
                        @foreach (var stage in Enum.GetValues<DealStage>())
                        {
                            <option value="@stage">@stage</option>
                        }
                    </InputSelect>
                </label>
            </div>

            @if (!string.IsNullOrWhiteSpace(dealDialogErrorMessage))
            {
                <div class="crm-alert crm-alert-danger">@dealDialogErrorMessage</div>
            }
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="crm-button crm-button-secondary" @onclick="CloseDealDialog">Close</button>
        <button type="button" class="crm-button crm-button-primary" @onclick="SaveDealStageAsync" disabled="@(selectedDeal is null || isSavingDealStage)">@(isSavingDealStage ? "Saving..." : "Update stage")</button>
    </FooterContent>
</CrmDialog>

@code {
    private string factor => FormFactor.GetFormFactor();
    private string platform => FormFactor.GetPlatform();
    private readonly List<CompanyDto> companies = [];
    private readonly List<ContactDto> contacts = [];
    private readonly List<DealDto> deals = [];
    private readonly List<CrmTaskDto> tasks = [];
    private readonly List<CrmUserDto> users = [];
    private readonly List<CrmActivityDto> recentActivities = [];
    private readonly HashSet<Guid> completingTaskIds = [];
    private DashboardSummaryDto dashboardSummary = new();
    private bool isCreateCompanyModalOpen;
    private bool isCreateContactModalOpen;
    private bool isCreateDealModalOpen;
    private bool isCreateTaskModalOpen;
    private bool isDealDialogOpen;
    private bool isLoading;
    private bool isSavingCompany;
    private bool isSavingContact;
    private bool isSavingDeal;
    private bool isSavingTask;
    private bool isSavingDealStage;
    private string? errorMessage;
    private string? companyModalErrorMessage;
    private string? modalErrorMessage;
    private string? dealModalErrorMessage;
    private string? taskModalErrorMessage;
    private string? dealDialogErrorMessage;
    private DealDto? selectedDeal;
    private DealStage selectedDealStage = DealStage.Lead;
    private CompanyFormModel companyForm = new();
    private ContactFormModel contactForm = new();
    private DealFormModel dealForm = new();
    private TaskFormModel taskForm = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var companiesTask = CrmApiClient.GetCompaniesAsync();
            var contactsTask = CrmApiClient.GetContactsAsync();
            var dealsTask = CrmApiClient.GetDealsAsync();
            var tasksTask = CrmApiClient.GetTasksAsync();
            var usersTask = CrmApiClient.GetUsersAsync();
            var dashboardTask = CrmApiClient.GetDashboardAsync();
            var activitiesTask = CrmApiClient.GetActivitiesAsync(12);

            await Task.WhenAll(companiesTask, contactsTask, dealsTask, tasksTask, usersTask, dashboardTask, activitiesTask);

            companies.Clear();
            companies.AddRange(await companiesTask);

            contacts.Clear();
            contacts.AddRange(await contactsTask);

            deals.Clear();
            deals.AddRange(await dealsTask);

            tasks.Clear();
            tasks.AddRange(await tasksTask);

            users.Clear();
            users.AddRange(await usersTask);

            recentActivities.Clear();
            recentActivities.AddRange(await activitiesTask);

            dashboardSummary = await dashboardTask;

            if (selectedDeal is not null)
            {
                selectedDeal = deals.FirstOrDefault(deal => deal.Id == selectedDeal.Id);
            }
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
            companies.Clear();
            contacts.Clear();
            deals.Clear();
            tasks.Clear();
            users.Clear();
            recentActivities.Clear();
            dashboardSummary = new DashboardSummaryDto();
        }
        finally
        {
            isLoading = false;
        }
    }

