<CrmErrorBoundary>
    <ChildContent>
        <Routes />
    </ChildContent>
    <ErrorContent>
        <div class="crm-dashboard">
            <section class="crm-card crm-panel crm-panel-wide">
                <div class="crm-panel-header">
                    <div>
                        <h2>Something went wrong</h2>
                        <p>An unexpected error occurred in the workspace.</p>
                    </div>
                </div>
                <div class="crm-alert crm-alert-danger">Please refresh the page or reopen the app. The error has been logged.</div>
            </section>
        </div>
    </ErrorContent>
</CrmErrorBoundary>
